[script] !change
  {initial} ::
    local maker = GetCell(15, 15)
    local label = CMWM:getObject("!cellname")
    self.step = CMWM.stepper({
      function()
        maker.id = 527
        label.text = "Cross Maker"
      end,
      function()
        maker.id = 531
        label.text = "Directional Cross Maker"
      end,
      -- ...
    }, 0)
  ::
  {subtick:} 
    {:index} first
    {:callback} ::
      if tick % 5 == 0 then
        self.step:step()
      end
    ::

[graphic] !cellname
  {type} label
  {text} ::Maker::
  {position} 1 1
  {size} 20 20
  {align} camera